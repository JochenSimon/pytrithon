  match category:
    case "Hiragana -> Romaji":
      challenge = [(h,r) for h,r in zip(hiragana, romaji)]
      en_line = True
    case "Katakana -> Romaji" :
      challenge = [(k,r) for k,r in zip(katakana, romaji)]
      en_line = True
    case "Mixed -> Romaji":
      challenge = [(a,r) for a,r in zip(hiragana+katakana, romaji*2)]
      en_line = True
    case "Romaji -> Hiragana":
      challenge = [(r,h) for r,h in zip(romaji, hiragana)][:-1]
      buttons = list(hiragana[:-1])
